{
  "version": 1,
  "limits": {
    "max_interior_match_complexity": 256,
    "max_pattern_codepoints": 262144,
    "max_total_pattern_codepoints": 1048576,
    "max_patterns": 64,
    "max_total_tokens": 4096,
    "max_total_match_complexity": 8192,
    "max_invocation_match_work": 8388608
  },
  "valid": [
    {
      "id": "literal-path",
      "pattern": "docs/readme.md",
      "matches": ["docs/readme.md"],
      "misses": ["docs/README.md", "readme.md", "docs/nested/readme.md"]
    },
    {
      "id": "star-includes-hidden",
      "pattern": "*.md",
      "matches": ["a.md", ".hidden.md", "é.md"],
      "misses": ["a.markdown", "nested/a.md"]
    },
    {
      "id": "question-is-one-unicode-code-point",
      "pattern": "?.md",
      "matches": ["a.md", "é.md", "😀.md"],
      "misses": ["ab.md", "nested/a.md"]
    },
    {
      "id": "character-class-range",
      "pattern": "[a-c].md",
      "matches": ["a.md", "b.md", "c.md"],
      "misses": ["A.md", "d.md", "ab.md"]
    },
    {
      "id": "character-class-negation",
      "pattern": "[!a-c].md",
      "matches": ["d.md", "😀.md"],
      "misses": ["a.md", "b.md", "ab.md"]
    },
    {
      "id": "character-class-edge-hyphen-is-literal",
      "pattern": "[-a].md",
      "matches": ["-.md", "a.md"],
      "misses": ["b.md"]
    },
    {
      "id": "star-does-not-cross-segments",
      "pattern": "docs/*.md",
      "matches": ["docs/a.md", "docs/.hidden.md"],
      "misses": ["docs/nested/a.md", "a.md"]
    },
    {
      "id": "leading-globstar-matches-zero-or-more-segments",
      "pattern": "**/*.md",
      "matches": ["a.md", "docs/a.md", ".hidden/a.md", "a/b/c.md"],
      "misses": ["a.yml", "docs/a.markdown"]
    },
    {
      "id": "middle-globstar-matches-zero-or-more-segments",
      "pattern": "a/**/b?.md",
      "matches": ["a/b1.md", "a/x/b2.md", "a/x/y/b😀.md"],
      "misses": ["b1.md", "a/b.md", "a/x/b12.md"]
    },
    {
      "id": "trailing-globstar",
      "pattern": "assets/**",
      "matches": ["assets", "assets/a.yaml", "assets/nested/b.yaml"],
      "misses": ["asset/a.yaml", "x/assets/a.yaml"]
    },
    {
      "id": "multiple-complete-globstars",
      "pattern": "**/docs/**/file.?ml",
      "matches": ["docs/file.yml", "a/docs/file.xml", "a/docs/b/file.yml"],
      "misses": ["a/doc/file.yml", "a/docs/file.yaml"]
    },
    {
      "id": "regex-punctuation-is-literal",
      "pattern": "a+(b).md",
      "matches": ["a+(b).md"],
      "misses": ["ab.md", "aaab.md"]
    },
    {
      "id": "empty-class-matches-nothing",
      "pattern": "[].md",
      "matches": [],
      "misses": ["a.md", "].md"]
    },
    {
      "id": "unicode-spelling-is-not-normalized",
      "pattern": "é/*.md",
      "matches": ["é/a.md"],
      "misses": ["é/a.md"]
    }
  ],
  "adversarial": [
    {
      "id": "long-question-token-chain",
      "shape": "question_segment",
      "length": 8192
    },
    {
      "id": "long-leading-star-segment",
      "shape": "leading_star_segment",
      "length": 1536
    },
    {
      "id": "long-literal-segment-chain",
      "shape": "literal_segments",
      "length": 1536
    },
    {
      "id": "long-leading-globstar-path",
      "shape": "leading_globstar",
      "length": 1536
    },
    {
      "id": "long-star-plus-required-suffix-miss",
      "shape": "star_required_suffix",
      "length": 100000
    },
    {
      "id": "repeated-globstars-collapse",
      "shape": "repeated_globstar",
      "length": 10000
    }
  ],
  "invalid": [
    { "id": "empty", "pattern": "", "reason": "empty" },
    { "id": "absolute", "pattern": "/docs/*.md", "reason": "absolute" },
    { "id": "drive-absolute", "pattern": "C:/docs/*.md", "reason": "drive_qualified" },
    { "id": "drive-relative", "pattern": "z:docs/*.md", "reason": "drive_qualified" },
    { "id": "backslash", "pattern": "docs\\*.md", "reason": "backslash" },
    { "id": "dot-segment", "pattern": "./*.md", "reason": "dot_segment" },
    { "id": "parent-segment", "pattern": "docs/../*.md", "reason": "dot_segment" },
    { "id": "unterminated-class", "pattern": "[abc.md", "reason": "unterminated_class" },
    { "id": "nested-unterminated-class", "pattern": "a/[x/b.md", "reason": "unterminated_class" },
    { "id": "partial-globstar", "pattern": "ab**cd.md", "reason": "partial_globstar" },
    { "id": "unicode-partial-globstar", "pattern": "é**.md", "reason": "partial_globstar" },
    { "id": "triple-star", "pattern": "***/*.md", "reason": "partial_globstar" },
    { "id": "globstar-prefix", "pattern": "a/**b/*.md", "reason": "partial_globstar" },
    { "id": "globstar-suffix", "pattern": "a/b**/*.md", "reason": "partial_globstar" },
    {
      "id": "interior-match-work-limit",
      "pattern": "*aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa*",
      "reason": "match_work_limit"
    }
  ]
}
