{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:metadata:v0",
  "title": "Draft softschema artifact metadata",
  "$defs": {
    "contractId": {
      "type": "string",
      "pattern": "^(?:[a-z0-9_]+(?:\\.[a-z0-9_]+)*:)?[A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z0-9_.-]+)?$"
    },
    "core": {
      "type": "object",
      "required": ["contract"],
      "properties": {
        "contract": { "$ref": "#/$defs/contractId" },
        "schema": { "type": "string", "minLength": 1 },
        "envelope": { "type": "string", "minLength": 1 },
        "status": { "enum": ["soft", "permissive", "enforced"] }
      }
    },
    "legacy": {
      "allOf": [
        { "$ref": "#/$defs/core" },
        { "unevaluatedProperties": false }
      ]
    },
    "format1": {
      "allOf": [
        { "$ref": "#/$defs/core" },
        {
          "type": "object",
          "required": ["format"],
          "properties": {
            "format": { "const": "1" },
            "extensions": {
              "type": "object",
              "propertyNames": { "type": "string", "minLength": 1 }
            }
          }
        },
        { "unevaluatedProperties": false }
      ]
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/contractId" },
    { "$ref": "#/$defs/legacy" },
    { "$ref": "#/$defs/format1" }
  ]
}
