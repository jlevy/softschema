{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:public-claims:v0",
  "title": "machine-checked public claims matrix",
  "type": "object",
  "required": ["schema_version", "claims"],
  "properties": {
    "schema_version": { "const": "1" },
    "claims": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["source", "targets"],
        "properties": {
          "source": {
            "type": "object",
            "required": ["path", "pointer"],
            "properties": {
              "path": { "enum": ["release-metadata.json", "conformance/manifest.yaml"] },
              "pointer": {
                "type": "string",
                "pattern": "^(?:/(?:[^~/]|~[01])*)*$"
              }
            },
            "additionalProperties": false
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "marker"],
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$",
                  "not": { "pattern": "(?:^|/)\\.\\.(?:/|$)" }
                },
                "marker": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
