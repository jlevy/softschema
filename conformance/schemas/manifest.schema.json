{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:manifest:v0",
  "title": "Draft softschema conformance manifest",
  "type": "object",
  "required": [
    "kit_version",
    "status",
    "schema_dialect",
    "artifact_formats",
    "profiles",
    "policies",
    "schemas",
    "cases"
  ],
  "properties": {
    "kit_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-draft\\.[0-9]+$"
    },
    "status": { "const": "draft" },
    "schema_dialect": { "const": "https://json-schema.org/draft/2020-12/schema" },
    "artifact_formats": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["frontmatter-md", "pure-yaml"] }
    },
    "policies": {
      "type": "object",
      "required": [
        "yaml_value_domain",
        "format",
        "references",
        "serialization",
        "hash"
      ],
      "properties": {
        "yaml_value_domain": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "minLength": 1 },
        "references": { "type": "string", "minLength": 1 },
        "serialization": { "type": "string", "minLength": 1 },
        "hash": { "const": "sha256" }
      },
      "additionalProperties": false
    },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/schemaEntry" }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/caseEntry" }
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "schemaEntry": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^urn:softschema:draft:conformance:[a-z0-9-]+:v0$"
        },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "caseEntry": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
