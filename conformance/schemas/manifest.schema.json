{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:manifest:v0",
  "title": "softschema conformance manifest",
  "type": "object",
  "required": [
    "kit_version",
    "status",
    "identifier_status",
    "target_namespace",
    "schema_dialect",
    "artifact_formats",
    "profiles",
    "defaults",
    "exit_codes",
    "result_formats",
    "agent_install_destinations",
    "policies",
    "vocabulary",
    "schemas",
    "vector_suites",
    "artifacts",
    "cases",
    "coverage"
  ],
  "properties": {
    "kit_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-draft\\.[0-9]+)?$"
    },
    "status": { "enum": ["draft", "released"] },
    "identifier_status": {
      "enum": ["draft-until-live-verification", "published"]
    },
    "target_namespace": {
      "const": "https://jlevy.github.io/softschema/schema/v1/"
    },
    "schema_dialect": { "const": "https://json-schema.org/draft/2020-12/schema" },
    "artifact_formats": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["frontmatter-md", "pure-yaml"] }
    },
    "defaults": {
      "type": "object",
      "required": ["artifact_profile", "validation_status", "authored_artifact_format"],
      "properties": {
        "artifact_profile": { "const": "frontmatter-md" },
        "validation_status": { "const": "soft" },
        "authored_artifact_format": { "const": "1" }
      },
      "additionalProperties": false
    },
    "exit_codes": {
      "type": "object",
      "required": ["all_passed", "validation_failed", "input_failed", "precedence"],
      "properties": {
        "all_passed": { "const": 0 },
        "validation_failed": { "const": 1 },
        "input_failed": { "const": 2 },
        "precedence": { "const": [2, 1, 0] }
      },
      "additionalProperties": false
    },
    "result_formats": {
      "type": "object",
      "required": ["legacy_single_file", "diagnostic", "jsonl", "sarif"],
      "properties": {
        "legacy_single_file": { "const": "validation-result-legacy" },
        "diagnostic": { "const": "diagnostic-v1" },
        "jsonl": { "const": "diagnostic-v1-record" },
        "sarif": { "const": "sarif-2.1.0" }
      },
      "additionalProperties": false
    },
    "agent_install_destinations": {
      "type": "object",
      "required": ["implicit_project_agents", "agents", "unsupported_agents"],
      "properties": {
        "implicit_project_agents": {
          "const": ["codex", "claude"]
        },
        "agents": {
          "type": "object",
          "required": [
            "codex",
            "claude",
            "gemini",
            "copilot",
            "cursor",
            "windsurf",
            "opencode",
            "cline",
            "roo"
          ],
          "additionalProperties": { "$ref": "#/$defs/installDestination" }
        },
        "unsupported_agents": {
          "type": "object",
          "required": ["aider"],
          "properties": {
            "aider": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "policies": {
      "type": "object",
      "required": [
        "yaml_value_domain",
        "format",
        "regex",
        "references",
        "resource_bundles",
        "canonicalization",
        "serialization",
        "hash"
      ],
      "properties": {
        "yaml_value_domain": { "type": "string", "minLength": 1 },
        "format": { "const": "annotation-only-v1" },
        "regex": { "const": "portable-regex-v1" },
        "references": { "const": "offline-only-v1" },
        "resource_bundles": { "const": "explicit-closed-bundle-v1" },
        "canonicalization": { "const": "semantics-preserving-v1" },
        "serialization": { "const": "portable-json-v1" },
        "hash": { "const": "sha256" }
      },
      "additionalProperties": false
    },
    "vocabulary": {
      "type": "object",
      "required": ["uri", "metaschema", "required"],
      "properties": {
        "uri": {
          "anyOf": [
            { "const": "urn:softschema:draft:vocabulary:x-softschema:v0" },
            { "const": "https://jlevy.github.io/softschema/schema/v1/vocab/x-softschema" }
          ]
        },
        "metaschema": { "const": "x-softschema.schema.json" },
        "required": { "const": false }
      },
      "additionalProperties": false
    },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/schemaEntry" }
    },
    "vector_suites": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/vectorEntry" }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifactEntry" }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/caseEntry" }
    },
    "coverage": {
      "type": "object",
      "required": [
        "artifact_format",
        "artifact_profiles",
        "core_api",
        "diagnostic_v1",
        "format_annotations",
        "legacy_result",
        "metadata",
        "nested_identities",
        "offline_resources",
        "portable_regex",
        "portable_values",
        "raw_canonicalization",
        "resource_bundles",
        "schema_errors",
        "version_negotiation"
      ],
      "additionalProperties": { "$ref": "#/$defs/coverageTargets" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "draft" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "kit_version": {
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-draft\\.[0-9]+$"
          },
          "identifier_status": { "const": "draft-until-live-verification" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "released" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "kit_version": { "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "identifier_status": { "const": "published" }
        }
      }
    }
  ],
  "$defs": {
    "path": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$",
      "not": { "pattern": "(?:(?:^|/)\\.{1,2}(?:/|$)|//|/$)" }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "schemaEntry": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^urn:softschema:draft:conformance:[a-z0-9-]+:v0$"
        },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "vectorEntry": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "artifactEntry": {
      "type": "object",
      "required": ["id", "role", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "role": {
          "enum": [
            "adapter",
            "consumer",
            "doctor-claims",
            "evolution",
            "implementation-matrix",
            "notice",
            "publication-candidate",
            "vendor-schema",
            "walkthrough"
          ]
        },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "schema": { "type": "string", "pattern": "^[a-z0-9-]+\\.schema\\.json$" }
      },
      "additionalProperties": false
    },
    "caseEntry": {
      "type": "object",
      "required": ["id", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "coverageTargets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(?:artifact|case|schema|suite):[A-Za-z0-9][A-Za-z0-9._/-]*$"
      }
    },
    "installDestination": {
      "type": "object",
      "required": ["project", "personal"],
      "properties": {
        "project": {
          "type": "string",
          "pattern": "^\\.[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        },
        "personal": {
          "type": "string",
          "pattern": "^\\.[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
