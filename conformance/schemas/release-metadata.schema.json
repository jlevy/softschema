{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:release-metadata:v0",
  "title": "Draft softschema logical release metadata",
  "type": "object",
  "required": [
    "schema_version",
    "release_state",
    "logical_version",
    "discovery_protocol",
    "packages",
    "artifact_formats",
    "conformance",
    "runtimes",
    "expected_artifacts"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "release_state": { "enum": ["development", "candidate", "released"] },
    "logical_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"
    },
    "discovery_protocol": { "type": "string", "minLength": 1 },
    "packages": {
      "type": "object",
      "required": ["python", "npm"],
      "properties": {
        "python": { "$ref": "#/$defs/package" },
        "npm": { "$ref": "#/$defs/package" }
      },
      "additionalProperties": false
    },
    "artifact_formats": {
      "type": "object",
      "required": ["current", "supported"],
      "properties": {
        "current": { "type": "string", "minLength": 1 },
        "supported": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "conformance": {
      "type": "object",
      "required": ["version", "status"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "status": { "enum": ["unavailable", "candidate", "release_asset"] }
      },
      "additionalProperties": false
    },
    "runtimes": {
      "type": "object",
      "required": ["python", "node", "bun"],
      "properties": {
        "python": { "$ref": "#/$defs/runtimeRange" },
        "node": { "$ref": "#/$defs/runtimeRange" },
        "bun": { "$ref": "#/$defs/runtimeRange" }
      },
      "additionalProperties": false
    },
    "expected_artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*$"
      }
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "required": ["name", "version", "pin"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "pin": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "runtimeRange": {
      "type": "object",
      "required": ["minimum"],
      "properties": {
        "minimum": { "type": "string", "minLength": 1 },
        "tested": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
