{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:x-softschema:v0",
  "$dynamicAnchor": "meta",
  "$vocabulary": {
    "https://json-schema.org/draft/2020-12/vocab/core": true,
    "https://json-schema.org/draft/2020-12/vocab/applicator": true,
    "https://json-schema.org/draft/2020-12/vocab/unevaluated": true,
    "https://json-schema.org/draft/2020-12/vocab/validation": true,
    "https://json-schema.org/draft/2020-12/vocab/meta-data": true,
    "https://json-schema.org/draft/2020-12/vocab/format-annotation": true,
    "https://json-schema.org/draft/2020-12/vocab/content": true,
    "urn:softschema:draft:vocabulary:x-softschema:v0": false
  },
  "title": "optional x-softschema annotation vocabulary metaschema",
  "allOf": [
    { "$ref": "https://json-schema.org/draft/2020-12/schema" }
  ],
  "$defs": {
    "contractId": {
      "type": "string",
      "pattern": "^(?:[a-z0-9_]+(?:\\.[a-z0-9_]+)*:)?[A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z0-9_.-]+)?$"
    },
    "compilerMetadata": {
      "type": "object",
      "required": ["contract", "schema_sha256", "softschema_format_version"],
      "properties": {
        "contract": { "$ref": "#/$defs/contractId" },
        "schema_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "softschema_format_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },
    "fieldAnnotation": {
      "type": "object",
      "required": ["group"],
      "properties": {
        "aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "examples": { "type": "array" },
        "group": { "type": "string", "minLength": 1 },
        "instruction": { "type": "string", "minLength": 1 },
        "order": { "type": "integer" },
        "owner": {
          "enum": ["agent", "postprocess", "system", "human"]
        },
        "repair": {
          "enum": ["none", "safe_coerce", "suggest_alias"]
        },
        "tier": {
          "enum": ["hard_fact", "constrained", "narrative"]
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "x-softschema": {
      "oneOf": [
        { "$ref": "#/$defs/compilerMetadata" },
        { "$ref": "#/$defs/fieldAnnotation" }
      ]
    }
  }
}
