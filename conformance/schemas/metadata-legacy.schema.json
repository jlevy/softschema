{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:metadata-legacy:v0",
  "title": "softschema legacy artifact metadata",
  "$defs": {
    "contractId": {
      "type": "string",
      "pattern": "^(?:[a-z0-9_]+(?:\\.[a-z0-9_]+)*:)?[A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z0-9_.-]+)?$"
    },
    "expanded": {
      "type": "object",
      "required": ["contract"],
      "properties": {
        "contract": { "$ref": "#/$defs/contractId" },
        "schema": { "type": "string", "minLength": 1 },
        "envelope": { "type": "string", "minLength": 1 },
        "status": { "enum": ["soft", "permissive", "enforced"] }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/contractId" },
    { "$ref": "#/$defs/expanded" }
  ]
}
