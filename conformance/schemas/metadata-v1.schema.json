{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:softschema:draft:conformance:metadata-v1:v0",
  "title": "Draft softschema artifact metadata format 1",
  "$defs": {
    "contractId": {
      "type": "string",
      "pattern": "^(?:[a-z0-9_]+(?:\\.[a-z0-9_]+)*:)?[A-Za-z_][A-Za-z0-9_]*(?:/[A-Za-z0-9_.-]+)?$"
    },
    "reverseDnsNamespace": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
    },
    "httpsNamespace": {
      "type": "string",
      "allOf": [
        {
          "pattern": "^https://(?:[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?|\\[[0-9a-f:]+\\])(?::[1-9][0-9]*)?/(?:[A-Za-z0-9._~!$&'()*+,;=:@/-]|%[0-9A-F]{2})*(?:\\?(?:[A-Za-z0-9._~!$&'()*+,;=:@/?-]|%[0-9A-F]{2})+)?$"
        },
        { "not": { "pattern": "^https://[^/]*:443/" } },
        { "not": { "pattern": "/\\./" } },
        { "not": { "pattern": "/\\.\\./" } },
        { "not": { "pattern": "/\\.$" } },
        { "not": { "pattern": "/\\.\\.$" } }
      ]
    },
    "extensionNamespace": {
      "oneOf": [
        { "$ref": "#/$defs/reverseDnsNamespace" },
        { "$ref": "#/$defs/httpsNamespace" }
      ]
    }
  },
  "type": "object",
  "required": ["format", "contract"],
  "properties": {
    "format": { "const": "1" },
    "contract": { "$ref": "#/$defs/contractId" },
    "schema": { "type": "string", "minLength": 1 },
    "envelope": { "type": "string", "minLength": 1 },
    "status": { "enum": ["soft", "permissive", "enforced"] },
    "extensions": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/extensionNamespace" }
    }
  },
  "additionalProperties": false
}
