{
  "format": "softschema-vector-suite-v1",
  "id": "metadata-v1",
  "description": "Compact and mapping metadata with opaque extensions.",
  "operation": "metadata",
  "cases": [
    {
      "id": "absent",
      "input": { "raw": null },
      "expected": { "ok": true, "value": null }
    },
    {
      "id": "compact",
      "input": { "raw": "example.docs:Record/v1" },
      "expected": {
        "ok": true,
        "value": {
          "contract": "example.docs:Record/v1",
          "schema": null,
          "envelope": null,
          "status": null
        }
      }
    },
    {
      "id": "expanded",
      "input": {
        "raw": {
          "contract": "example.docs:Record/v1",
          "schema": "record.schema.yaml",
          "envelope": "record",
          "status": "enforced"
        }
      },
      "expected": {
        "ok": true,
        "value": {
          "contract": "example.docs:Record/v1",
          "schema": "record.schema.yaml",
          "envelope": "record",
          "status": "enforced"
        }
      }
    },
    {
      "id": "extensions",
      "input": {
        "raw": {
          "contract": "example.docs:Record/v1",
          "extensions": {
            "com.example.review": { "enabled": true, "labels": ["ready", 2, null] }
          }
        }
      },
      "expected": {
        "ok": true,
        "value": {
          "contract": "example.docs:Record/v1",
          "schema": null,
          "envelope": null,
          "status": null,
          "extensions": {
            "com.example.review": { "enabled": true, "labels": ["ready", 2, null] }
          }
        }
      }
    },
    {
      "id": "format-key-rejected",
      "input": { "raw": { "format": "1", "contract": "example.docs:Record/v1" } },
      "expected": { "ok": false }
    },
    {
      "id": "empty-extensions",
      "input": {
        "raw": { "contract": "example.docs:Record/v1", "extensions": {} }
      },
      "expected": {
        "ok": true,
        "value": {
          "contract": "example.docs:Record/v1",
          "schema": null,
          "envelope": null,
          "status": null,
          "extensions": {}
        }
      }
    },
    {
      "id": "unknown-top-level-key-rejected",
      "input": {
        "raw": { "contract": "example.docs:Record/v1", "future": true }
      },
      "expected": { "ok": false }
    },
    {
      "id": "invalid-extension-namespace-rejected",
      "input": {
        "raw": {
          "contract": "example.docs:Record/v1",
          "extensions": { "Example.Invalid": true }
        }
      },
      "expected": { "ok": false }
    }
  ]
}
