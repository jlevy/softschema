{
  "name": "softschema",
  "version": "0.1.3",
  "description": "Soft schema conventions and validation for Markdown/YAML artifacts (TypeScript/Zod).",
  "license": "MIT",
  "author": "Joshua Levy (https://github.com/jlevy)",
  "homepage": "https://github.com/jlevy/softschema",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jlevy/softschema.git",
    "directory": "packages/typescript"
  },
  "bugs": {
    "url": "https://github.com/jlevy/softschema/issues"
  },
  "keywords": [
    "softschema",
    "soft schema",
    "frontmatter",
    "yaml",
    "markdown",
    "json-schema",
    "zod",
    "validation",
    "agent",
    "cli"
  ],
  "type": "module",
  "bin": {
    "softschema": "dist/cli.js",
    "softschema-ts": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "resources", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "copy-resources": "bun scripts/copy-resources.ts",
    "build": "bun scripts/copy-resources.ts && bunup",
    "test": "bun test",
    "test:cov": "bun test --coverage",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && tsc --noEmit && bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "atomically": "^2.1.1",
    "commander": "^15.0.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "^1.3.0",
    "bunup": "^0.16.31",
    "typescript": "^6.0.3"
  }
}
