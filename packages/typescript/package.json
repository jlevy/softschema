{
  "name": "@softschema/core",
  "version": "0.0.0",
  "description": "Soft schema conventions and validation for Markdown/YAML artifacts (TypeScript/Zod).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "softschema-ts": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "resources"],
  "scripts": {
    "copy-resources": "bun scripts/copy-resources.ts",
    "build": "bun scripts/copy-resources.ts && bunup",
    "test": "bun test",
    "test:cov": "bun test --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && tsc --noEmit && bun test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "atomically": "^2.1.1",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "bunup": "^0.16.31",
    "typescript": "^6.0.3"
  }
}
