# Directories and files flowmark should never touch.
# Uses gitignore syntax; lives at repo root.
# Flowmark-rs also honors .gitignore, so paths listed there
# (dist/, .venv/, node_modules/, __pycache__/, etc.) do not
# need to be repeated here.

# Third-party agent state vendored by `tbd setup`; managed externally
# and overwritten on resync.
.tbd/
.claude/skills/tbd/
.codex/

# Skill mirrors written by `softschema skill --install`; the canonical
# source is skills/softschema/SKILL.md, and these copies are regenerated
# byte-deterministically by the CLI.
.agents/skills/softschema/
.claude/skills/softschema/

# Beads issue store; managed by tbd, not human-authored.
.beads/

# Golden-test corpus: scenario files capture exact CLI output byte-for-byte.
# Reflowing prose or tables here would corrupt the expected output.
tests/golden/

# Language-neutral conformance cases are digest-addressed test vectors. Format the
# conformance README normally, but never rewrite case artifacts or expected bytes.
conformance/cases/
